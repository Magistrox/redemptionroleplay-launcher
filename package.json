{
  "name": "redemption-launcher",
  "version": "1.0.7",
  "description": "Redemption roleplay — Launcher",
  "main": "main.js",
  "scripts": {
    "start":   "electron .",
    "predist":    "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && node scripts/make-icon.js",
    "prerelease": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && node scripts/make-icon.js",
    "dist":       "electron-builder --win",
    "release":    "electron-builder --win --publish=always"
  },
  "build": {
    "appId": "xyz.redemptionrp.launcher",
    "productName": "Redemption roleplay — Launcher",
    "directories": { "output": "dist" },
    "files": ["**/*", "!dist/**", "!node_modules/.cache/**"],
    "win": {
      "icon": "assets/img/logo.ico",
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "artifactName": "Redemption roleplay.exe"
    },
    "publish": {
      "provider":    "github",
      "owner":       "Magistrox",
      "repo":        "redemptionroleplay-launcher",
      "releaseType": "release"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "electron":         "^33.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico":       "^2.1.8"
  }
}
